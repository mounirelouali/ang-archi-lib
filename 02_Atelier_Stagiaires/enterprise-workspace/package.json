{
  "name": "@ang-archi-lib/enterprise-workspace",
  "version": "1.0.0",
  "private": true,
  "description": "Workspace Nx Monorepo - Formation complète J0-J3 (1 seul node_modules)",
  "scripts": {
    "j0:ts:generics": "npx nx run j0-examples:generics",
    "j0:ts:utility": "npx nx run j0-examples:utility",
